package com.hospital.management.scheduling.service;

import com.hospital.management.scheduling.event.AppointmentEvent;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.context.event.EventListener;
import org.springframework.scheduling.annotation.Async;
import org.springframework.stereotype.Component;

@Component
public class NotificationListener {

    private static final Logger log = LoggerFactory.getLogger(NotificationListener.class);

    @Async
    @EventListener
    public void handleAppointmentEvent(AppointmentEvent event) {
        String patientId = String.valueOf(event.appointment().getPatientId());
        String doctorName = event.appointment().getDoctor().getName();
        String date = event.appointment().getAppointmentDate().toString();
        String time = event.appointment().getTimeSlot().toString();

        log.info("Processing asynchronous notification for Patient ID: {}", patientId);
        
        switch (event.actionType()) {
            case "BOOKED" -> log.info("NOTIFICATION SENT: Appointment successfully CONFIRMED for doctor {} on {} at {}.", doctorName, date, time);
            case "CANCELLED" -> log.info("NOTIFICATION SENT: Appointment with doctor {} on {} has been CANCELLED.", doctorName, date);
            case "RESCHEDULED" -> log.info("NOTIFICATION SENT: Appointment successfully RESCHEDULED with doctor {} to {} at {}.", doctorName, date, time);
            default -> log.warn("Unknown appointment action type: {}", event.actionType());
        }
    }
}

