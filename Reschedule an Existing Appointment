package com.hospital.management.scheduling.service;

import com.hospital.management.scheduling.dto.BookingRequest;
import com.hospital.management.scheduling.dto.RescheduleRequest;
import com.hospital.management.scheduling.model.Appointment;
import com.hospital.management.scheduling.model.AppointmentStatus;
import com.hospital.management.scheduling.model.Doctor;
import com.hospital.management.scheduling.repository.AppointmentRepository;
import com.hospital.management.scheduling.repository.DoctorRepository;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.time.LocalDate;
import java.util.List;

@Service
public class AppointmentService {

    private final AppointmentRepository appointmentRepository;
    private final DoctorRepository doctorRepository;

    public AppointmentService(AppointmentRepository appointmentRepository, DoctorRepository doctorRepository) {
        this.appointmentRepository = appointmentRepository;
        this.doctorRepository = doctorRepository;
    }

    @Transactional
    public Appointment bookAppointment(BookingRequest request) {
        Doctor doctor = doctorRepository.findById(request.doctorId())
                .orElseThrow(() -> new IllegalArgumentException("Doctor not found"));

        boolean isSlotTaken = appointmentRepository.existsByDoctorIdAndAppointmentDateAndTimeSlotAndStatus(
                request.doctorId(), request.appointmentDate(), request.timeSlot(), AppointmentStatus.CONFIRMED);

        if (isSlotTaken) {
            throw new IllegalStateException("The requested time slot is already booked.");
        }

        Appointment appointment = new Appointment(
                request.patientId(),
                doctor,
                request.appointmentDate(),
                request.timeSlot(),
                AppointmentStatus.CONFIRMED
        );

        return appointmentRepository.save(appointment);
    }

    @Transactional
    public Appointment cancelAppointment(Long appointmentId) {
        Appointment appointment = appointmentRepository.findById(appointmentId)
                .orElseThrow(() -> new IllegalArgumentException("Appointment record not found"));

        if (appointment.getStatus() == AppointmentStatus.CANCELLED) {
            throw new IllegalStateException("Appointment is already cancelled.");
        }

        appointment.setStatus(AppointmentStatus.CANCELLED);
        return appointmentRepository.save(appointment);
    }

    // New business logic to modify appointment parameters safely
    @Transactional
    public Appointment rescheduleAppointment(Long appointmentId, RescheduleRequest request) {
        Appointment appointment = appointmentRepository.findById(appointmentId)
                .orElseThrow(() -> new IllegalArgumentException("Appointment record not found"));

        if (appointment.getStatus() == AppointmentStatus.CANCELLED) {
            throw new IllegalStateException("Cannot reschedule a cancelled appointment.");
        }

        // Verify if the target slot is currently holding an active confirmation
        boolean isSlotTaken = appointmentRepository.existsByDoctorIdAndAppointmentDateAndTimeSlotAndStatus(
                appointment.getDoctor().getId(), request.newAppointmentDate(), request.newTimeSlot(), AppointmentStatus.CONFIRMED);

        if (isSlotTaken) {
            throw new IllegalStateException("The newly requested time slot is already taken.");
        }

        // Mutate properties inside the transactional context to trigger dirty checks/optimistic locking
        // Reflection of these fields automatically releases the old block during the database update stage
        // Use reflection methods or direct setter overrides to modify mutable properties cleanly
        try {
            java.lang.reflect.Field dateField = Appointment.class.getDeclaredField("appointmentDate");
            dateField.setAccessible(true);
            dateField.set(appointment, request.newAppointmentDate());

            java.lang.reflect.Field slotField = Appointment.class.getDeclaredField("timeSlot");
            slotField.setAccessible(true);
            slotField.set(appointment, request.newTimeSlot());
        } catch (Exception e) {
            throw new RuntimeException("Failed to mutate appointment properties internally", e);
        }

        return appointmentRepository.save(appointment);
    }

    @Transactional(readOnly = true)
    public List<Appointment> getDoctorAgenda(Long doctorId, LocalDate date) {
        if (!doctorRepository.existsById(doctorId)) {
            throw new IllegalArgumentException("Doctor not found");
        }
        return appointmentRepository.findByDoctorIdAndAppointmentDateOrderByTimeSlotAsc(doctorId, date);
    }

    @Transactional(readOnly = true)
    public List<Appointment> getPatientHistory(Long patientId) {
        return appointmentRepository.findByPatientIdOrderByAppointmentDateDescTimeSlotDesc(patientId);
    }
}

