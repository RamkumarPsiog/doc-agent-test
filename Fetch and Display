package com.hospital.management.scheduling.service;

import com.hospital.management.scheduling.model.Doctor;
import com.hospital.management.scheduling.model.AvailabilityWindow;
import com.hospital.management.scheduling.repository.DoctorRepository;
import org.springframework.stereotype.Service;

import java.time.LocalDate;
import java.time.LocalTime;
import java.util.ArrayList;
import java.util.List;

@Service
public class AvailabilityService {

    private final DoctorRepository doctorRepository;

    public AvailabilityService(DoctorRepository doctorRepository) {
        this.doctorRepository = doctorRepository;
    }

    public List<LocalTime> getAvailableSlots(Long doctorId, LocalDate date) {
        Doctor doctor = doctorRepository.findById(doctorId)
                .orElseThrow(() -> new IllegalArgumentException("Doctor not found"));

        List<LocalTime> slots = new ArrayList<>();
        
        // Find if the doctor has a shift on this specific day of the week
        for (AvailabilityWindow window : doctor.getAvailabilityWindows()) {
            if (window.getDayOfWeek() == date.getDayOfWeek()) {
                LocalTime current = window.getStartTime();
                while (current.isBefore(window.getEndTime())) {
                    slots.add(current);
                    current = current.plusMinutes(30); // 30-minute default slots
                }
            }
        }
        
        // Note: Slot filtering against booked appointments will be wired up in the next story's commit
        return slots;
    }
}


