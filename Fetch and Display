package com.hospital.management.scheduling.model;

import jakarta.persistence.*;
import java.util.List;

@Entity
@Table(name = "doctors")
public class Doctor {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;
    
    private String name;
    private String specialty;

    @ElementCollection
    @CollectionTable(name = "doctor_availability_windows", joinColumns = @JoinColumn(name = "doctor_id"))
    private List<AvailabilityWindow> availabilityWindows;

    // Getters, Setters, Constructors
    public Doctor() {}
    public Doctor(String name, String specialty, List<AvailabilityWindow> availabilityWindows) {
        this.name = name;
        this.specialty = specialty;
        this.availabilityWindows = availabilityWindows;
    }
    public Long getId() { return id; }
    public String getName() { return name; }
    public List<AvailabilityWindow> getAvailabilityWindows() { return availabilityWindows; }
}

